PROJECT_NAME=yaai

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

BOT_TOKEN=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=yaai

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_API_KEY=

DEFAULT_TEXT_MODEL_ID=2
DEFAULT_IMAGE_MODEL_ID=6
DEFAULT_VIDEO_MODEL_ID=11

MEMPALACE_ENABLED=true
MEMPALACE_PALACE_PATH=./data/mempalace/palace
MEMPALACE_ROOM=telegram
MEMPALACE_TOP_K=5

VIDEO_MAX_FRAMES=5

PYTHONUNBUFFERED=1
ENVIRONMENT=production
